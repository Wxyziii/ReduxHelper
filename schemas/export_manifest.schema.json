{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Redux Export Manifest",
  "type": "object",
  "required": [
    "projectName",
    "exportName",
    "createdAt",
    "sectionsIncluded",
    "files",
    "warnings"
  ],
  "properties": {
    "projectName": {
      "type": "string"
    },
    "exportName": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "sectionsIncluded": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "section",
          "relativePath",
          "exportPath",
          "status"
        ],
        "properties": {
          "section": {
            "type": "string"
          },
          "sourcePath": {
            "type": "string"
          },
          "relativePath": {
            "type": "string"
          },
          "exportPath": {
            "type": "string"
          },
          "backupPath": {
            "type": "string"
          },
          "changeCount": {
            "type": "number"
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
